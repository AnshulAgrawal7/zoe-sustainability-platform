// PROTOTYPE SCHEMA — ZOE Sustainability Platform
// PostgreSQL (Supabase). Enums kept as String (validated at the application
// layer) for portability — works identically on Postgres and SQLite.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL") // pooled (PgBouncer, 6543) — used by the app
  directUrl = env("DIRECT_URL") // direct (5432) — used by Prisma migrations
}

// Role: "USER" | "ADMIN"
// Language: "EN" | "EL" | "DE"
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  // Public pseudonymous handle — shown in all community contexts (comments,
  // leaderboard, @mentions) INSTEAD of the real name/email. Unique, lowercased.
  username  String   @unique
  password  String
  name      String
  role      String   @default("USER")
  points    Int      @default(0)
  avatarUrl String?
  language  String   @default("EN")
  profile   String   @default("RESIDENT") // RESIDENT | VISITOR | STUDENT | VOLUNTEER (self-selected, optional)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  participations       Participation[]
  eventRegistrations   EventRegistration[]
  ideas                Idea[]
  submissions          Submission[]
  eventProposals       EventProposal[]
  userBadges           UserBadge[]
  refreshTokens        RefreshToken[]
  createdProjects      Project[]           @relation("CreatedBy")
  comments             Comment[]
  commentLikes         CommentLike[]
  ideaVotes            IdeaVote[]
  notifications        Notification[]      @relation("Recipient")
  actorNotifications   Notification[]      @relation("Actor")
}

// category: "ENVIRONMENT" | "MOBILITY" | "COMMUNITY" | "EDUCATION" | "CULTURE"
// status:   "DRAFT" | "OPEN" | "CLOSED" | "COMPLETED"
model Project {
  id              String    @id @default(cuid())
  titleEn         String
  titleEl         String
  titleDe         String
  descriptionEn   String
  descriptionEl   String
  descriptionDe   String
  // Value chain (Hammer & Champy 1993): Input -> Activity -> Output, trilingual,
  // optional. Shown on the project detail page only when filled. Programme facts.
  inputResourcesEn String?
  inputResourcesEl String?
  inputResourcesDe String?
  keyActivitiesEn  String?
  keyActivitiesEl  String?
  keyActivitiesDe  String?
  outputResultsEn  String?
  outputResultsEl  String?
  outputResultsDe  String?
  sdgIds          String // JSON array: "[3, 11, 13]"
  category        String
  status          String    @default("OPEN")
  // false = structural/umbrella project (e.g. ZOE programme): hidden from public
  // lists, counts, teasers & filters, but still reachable by direct link.
  listed          Boolean   @default(true)
  maxParticipants Int?
  rewardPoints    Int       @default(50)
  imageUrl        String?
  location        String?
  lat             Float? // optional map coordinate (WGS84); paired with lng
  lng             Float?
  startDate       DateTime?
  endDate         DateTime?
  sourceNote      String? // provenance, e.g. "Verde.tec 2026 / life-news.gr" (programme fact, not measured impact)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  createdBy         User               @relation("CreatedBy", fields: [createdById], references: [id])
  createdById       String
  participations    Participation[]
  posts             Post[]
  events            Event[]
  learningResources LearningResource[]
  metrics           ProjectMetric[]
}

// Documented impact figure for a project (Z1). Only REAL, sourced figures are
// stored here; a project with no rows has no measured impact yet (the UI then
// shows "not yet measured" rather than an invented number). One project may have
// several figures (e.g. tonnes diverted, diversion rate, streams).
model ProjectMetric {
  id        String   @id @default(cuid())
  project   Project  @relation(fields: [projectId], references: [id])
  projectId String
  labelEn   String
  labelEl   String
  labelDe   String
  value     String // kept as text to preserve the exact documented figure
  unit      String?
  source    String?
  createdAt DateTime @default(now())

  @@index([projectId])
}

// Self-contained, locally-grounded educational content (Z5). Trilingual; optionally
// linked to a real Project and/or SDGs. Body is longer text/Markdown. Admin-managed.
model LearningResource {
  id         String   @id @default(cuid())
  titleEn    String
  titleEl    String
  titleDe    String
  bodyEn     String
  bodyEl     String
  bodyDe     String
  category   String
  sdgIds     String   @default("[]") // JSON array, e.g. "[14, 15]"
  imageUrl   String?
  sourceNote String?
  project    Project? @relation(fields: [projectId], references: [id])
  projectId  String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([projectId])
}

// A concrete, dated event/appointment (e.g. a beach cleanup on 12.07.). Belongs
// to a Project (one project has many events). Trilingual like Project. `category`
// reuses PROJECT_CATEGORIES (validated at the application layer, see constants.ts).
// Attendance is tracked in EventRegistration. Points are NOT awarded on
// registration: an admin marks the event COMPLETED (lifecycle below), and only
// then do registered logged-in users receive `rewardPoints` (guests earn none).
// status: "UPCOMING" | "COMPLETED" (String, validated at the application layer)
model Event {
  id            String   @id @default(cuid())
  titleEn       String
  titleEl       String
  titleDe       String
  descriptionEn String
  descriptionEl String
  descriptionDe String
  date          DateTime
  location      String?
  lat           Float? // optional map coordinate (WGS84), geocoded from `location`
  lng           Float?
  category      String
  status        String   @default("UPCOMING")
  rewardPoints  Int      @default(20)
  capacity      Int?
  imageUrl      String? // cover image — Supabase Storage public URL (upload or external)
  projectId     String
  project       Project  @relation(fields: [projectId], references: [id], onDelete: Restrict)
  comments      Comment[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([projectId])
  @@index([date])
}

// News / blog feed. Auto-created when a project goes live (OPEN) or is completed,
// or written manually by an admin. Trilingual (EN/EL/DE).
// type: "PROJECT_NEW" | "PROJECT_COMPLETED" | "ANNOUNCEMENT"
model Post {
  id        String   @id @default(cuid())
  type      String   @default("ANNOUNCEMENT")
  titleEn   String
  titleEl   String
  titleDe   String
  bodyEn    String
  bodyEl    String
  bodyDe    String
  imageUrl  String?
  published Boolean  @default(true)
  projectId String?
  project   Project? @relation(fields: [projectId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Participation {
  id            String   @id @default(cuid())
  user          User     @relation(fields: [userId], references: [id])
  userId        String
  project       Project  @relation(fields: [projectId], references: [id])
  projectId     String
  joinedAt      DateTime @default(now())
  pointsAwarded Int      @default(0)

  @@unique([userId, projectId])
}

// Event RSVP. `eventId` is a DELIBERATELY SOFT reference to Event.id (no enforced
// FK): the Event model was introduced later and a hard FK on this pre-existing
// column would reject historical rows, so existence is validated at the
// application layer instead (see eventController). Seeded events reuse the legacy
// `evt-*` ids, so older registrations stay meaningfully linked.
// Registration is open WITHOUT an account to lower the barrier: guests provide
// name + email + consent (no points). Logged-in users register via `userId` and
// earn points. NULL userId rows (guests) are unconstrained by the unique index
// (Postgres treats NULLs as distinct), so many guests may register.
model EventRegistration {
  id            String   @id @default(cuid())
  eventId       String
  user          User?    @relation(fields: [userId], references: [id])
  userId        String?
  guestName     String?
  guestEmail    String?
  pointsAwarded Int      @default(0)
  createdAt     DateTime @default(now())

  @@unique([userId, eventId])
  @@index([eventId])
}

// Citizen-submitted idea / proposal (goal Z3). Open to everyone WITHOUT an
// account; a valid token links `userId`, otherwise the submission is anonymous
// (optional submitterName/submitterEmail). `category` reuses the Project category
// values (validated at the application layer, see constants.ts). Reviewed by
// admins via /admin/ideas — there is no email dispatch (Future Work).
// status: "NEW" | "IN_REVIEW" | "ACCEPTED" | "DECLINED"
model Idea {
  id             String   @id @default(cuid())
  title          String
  description    String
  category       String
  status         String   @default("NEW")
  submitterName  String?
  submitterEmail String?
  user           User?    @relation(fields: [userId], references: [id])
  userId         String?
  createdAt      DateTime @default(now())
  comments       Comment[]
  votes          IdeaVote[]

  @@index([status])
}

// One supporting vote per user per idea (toggle) — citizen prioritization of the
// approved idea board ("participatory budgeting" light). Composite PK enforces
// uniqueness, mirroring CommentLike.
model IdeaVote {
  idea      Idea     @relation(fields: [ideaId], references: [id], onDelete: Cascade)
  ideaId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  createdAt DateTime @default(now())

  @@id([ideaId, userId])
  @@index([ideaId])
}

// Citizen report (environmental issue) or general feedback from /participate.
// Mirrors Idea: open WITHOUT an account — a valid token links `userId`, otherwise
// the submission is anonymous (optional submitterName/submitterEmail). Admins see
// these in a read-only overview (/admin/submissions); no review workflow yet
// (Future Work).
// type: "REPORT" | "FEEDBACK"
model Submission {
  id             String   @id @default(cuid())
  type           String
  message        String
  submitterName  String?
  submitterEmail String?
  user           User?    @relation(fields: [userId], references: [id])
  userId         String?
  createdAt      DateTime @default(now())

  @@index([type])
}

// Citizen-submitted EVENT proposal (community). Unlike an Idea, this is NOT shown
// on the public idea board: an admin reviews it and, on approval, it is converted
// into a real Event (the admin form is pre-filled with these fields and the single
// source language is auto-translated into EN/EL/DE). Open WITHOUT an account; a
// valid token links `userId`, otherwise anonymous (optional submitterName/Email).
// lang: source language "EN" | "EL" | "DE". status: "NEW" | "CONVERTED" | "DECLINED".
model EventProposal {
  id             String    @id @default(cuid())
  title          String
  description    String
  lang           String    @default("EN")
  category       String
  date           DateTime
  location       String?
  lat            Float?
  lng            Float?
  capacity       Int?
  rewardPoints   Int?
  imageUrl       String?
  projectId      String? // suggested project (optional; admin confirms/assigns)
  status         String    @default("NEW")
  submitterName  String?
  submitterEmail String?
  user           User?     @relation(fields: [userId], references: [id])
  userId         String?
  createdEventId String? // the Event created from this proposal, once converted
  createdAt      DateTime  @default(now())

  @@index([status])
}

// In-app notification for a USER (e.g. "X mentioned you in a comment"). Drives the
// citizen-facing bell. `read` clears the unread count. `type`: "MENTION" (only kind
// for now). `actor` is who triggered it; commentId/eventId/ideaId give the target
// link. Distinct from the ADMIN bell, which is computed (no rows).
model Notification {
  id        String   @id @default(cuid())
  user      User     @relation("Recipient", fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  type      String   @default("MENTION")
  actor     User?    @relation("Actor", fields: [actorId], references: [id])
  actorId   String?
  comment   Comment? @relation(fields: [commentId], references: [id], onDelete: Cascade)
  commentId String?
  eventId   String?
  ideaId    String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, read])
}

// Discourse on an APPROVED citizen idea (Z3) OR an event (community networking).
// Exactly ONE of ideaId/eventId is set (enforced at the application layer). Only
// logged-in users post (anti-spam, Decide-Madrid/Consul style); admins moderate
// via `status`. status: "VISIBLE" | "HIDDEN" (hidden comments never appear).
model Comment {
  id        String        @id @default(cuid())
  idea      Idea?         @relation(fields: [ideaId], references: [id])
  ideaId    String?
  event     Event?        @relation(fields: [eventId], references: [id], onDelete: Cascade)
  eventId   String?
  user      User          @relation(fields: [userId], references: [id])
  userId    String
  body      String
  status    String        @default("VISIBLE")
  createdAt DateTime      @default(now())
  likes     CommentLike[]
  mentions  Notification[]

  @@index([ideaId])
  @@index([eventId])
}

// One like per user per comment (toggle). Composite PK enforces uniqueness.
model CommentLike {
  comment   Comment  @relation(fields: [commentId], references: [id])
  commentId String
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  createdAt DateTime @default(now())

  @@id([commentId, userId])
}

// One of the five ZOE levels (Σπόρος … Θεματοφύλακας). Admin-editable via
// /admin/rewards: point ranges, icon and the Greek name live here; the
// role-specific designation + reward list per audience live in RewardTierRole.
// `pointsMax = null` marks the open-ended top tier. The frontend keeps a static
// copy (src/data/rewards.ts + i18n) as PROTOTYPE FALLBACK when the API is down.
model RewardTier {
  id        String @id // sporos | phyllo | kladi | fylakas | thematofylakas
  order     Int    @unique
  greekName String
  icon      String // emoji, e.g. 🌱
  pointsMin Int
  pointsMax Int?

  roleVariants RewardTierRole[]
}

// Role-specific level designation + rewards for one tier (4 roles × 5 tiers).
// `rewards*` are newline-separated lists (one reward per line) — simple to edit
// in an admin textarea, split into arrays by the API consumers.
model RewardTierRole {
  id            String     @id @default(cuid())
  tier          RewardTier @relation(fields: [tierId], references: [id], onDelete: Cascade)
  tierId        String
  role          String // RESIDENT | VISITOR | STUDENT | VOLUNTEER
  nameEn        String
  nameEl        String
  nameDe        String
  descriptionEn String
  descriptionEl String
  descriptionDe String
  rewardsEn     String
  rewardsEl     String
  rewardsDe     String

  @@unique([tierId, role])
}

model Badge {
  id        String @id @default(cuid())
  nameEn    String
  nameEl    String
  nameDe    String
  descEn    String
  descEl    String
  descDe    String
  iconName  String
  threshold Int

  userBadges UserBadge[]
}

model UserBadge {
  user     User     @relation(fields: [userId], references: [id])
  userId   String
  badge    Badge    @relation(fields: [badgeId], references: [id])
  badgeId  String
  earnedAt DateTime @default(now())

  @@id([userId, badgeId])
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
}

// --- "What's New" feed (imported VBM Kokkali Facebook posts). Kept SEPARATE
// from the existing `Post` model (project lifecycle news), which is read-only
// merged into the public feed via an adapter — see feedController. ---

enum PostCategory {
  ANNOUNCEMENT
  EVENT
  PROJECT
  NEWS
}

enum EventStatus {
  UPCOMING
  COMPLETED
}

// One imported Facebook post. `sourceFolder` (folder number) is the natural key
// for idempotent re-imports. Original Greek text is authoritative; DE/EN are
// DeepL machine translations flagged for review.
model FeedPost {
  id           String       @id @default(cuid())
  category     PostCategory
  eventStatus  EventStatus? // only meaningful when category = EVENT
  publishedAt  DateTime // from line 1 of the .txt (DD.MM.YYYY)
  sourceFolder String       @unique
  needsReview  Boolean      @default(true)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  translations FeedPostTranslation[]
  images       FeedPostImage[]
}

model FeedPostTranslation {
  id                  String   @id @default(cuid())
  post                FeedPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  postId              String
  locale              String // 'el' | 'de' | 'en'
  title               String // short generated headline (<= ~80 chars)
  body                String   @db.Text
  isMachineTranslated Boolean  @default(false) // false for el, true for de/en

  @@unique([postId, locale])
}

model FeedPostImage {
  id          String   @id @default(cuid())
  post        FeedPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  postId      String
  storagePath String // path inside the Supabase bucket
  publicUrl   String
  order       Int
  width       Int? // against layout shift
  height      Int?

  altTexts FeedPostImageAltText[]

  @@index([postId])
}

// Trilingual alt text per image (WCAG 2.1 AA). `text = ""` means a deliberately
// decorative image (correct empty-alt behaviour). Mirrors FeedPostTranslation:
// one row per (image, locale), with a per-language review flag.
model FeedPostImageAltText {
  id          String        @id @default(cuid())
  image       FeedPostImage @relation(fields: [imageId], references: [id], onDelete: Cascade)
  imageId     String
  locale      String // 'el' | 'de' | 'en'
  text        String
  needsReview Boolean       @default(true)

  @@unique([imageId, locale])
}

// --- Privacy-by-design monitoring (admin dashboard) ---------------------
// AGGREGATE-ONLY counters: one row per day × path with a counter. There are
// deliberately NO visitor-level rows, no IPs, no user agents, no cookies —
// nothing personal is ever stored, so no consent banner is required.
// `day` is a UTC date string (YYYY-MM-DD); /admin paths are never recorded.

model PageViewDaily {
  day   String // YYYY-MM-DD (UTC)
  path  String
  count Int    @default(0)

  @@id([day, path])
}

// One counter per day for "visits" (browser sessions): the client reports a
// visit once per sessionStorage lifetime — an approximation, never identity.
model SiteVisitDaily {
  day   String @id // YYYY-MM-DD (UTC)
  count Int    @default(0)
}

// Newsletter opt-in touchpoint (F). PROTOTYPE: this only RECORDS an email +
// locale — there is NO mailing/double-opt-in/unsubscribe system (Future Work).
// `email` is unique so re-submitting the same address is a no-op (idempotent).
model NewsletterSignup {
  id        String   @id @default(cuid())
  email     String   @unique
  locale    String // 'en' | 'el' | 'de'
  createdAt DateTime @default(now())
}
