# ─────────────────────────────────────────────────────────────────────────────
# DATABASE (copy to backend/.env). Prisma provider = postgresql.
# Use a Supabase (or any Postgres) project. Pooled (6543) for the app,
# direct (5432) for migrations. Get both strings: Supabase → Connect → ORMs → Prisma.
# ─────────────────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres.<ref>:<PASSWORD>@<region>.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.<ref>:<PASSWORD>@<region>.pooler.supabase.com:5432/postgres"

# Local Postgres test DB for `npm test` (backend/docker-compose.yml → docker compose up -d).
# Tests run a destructive reset → this must NEVER point at Supabase/production.
TEST_DATABASE_URL="postgresql://zoe:zoe@localhost:5433/zoe_test"

JWT_SECRET="change-this-in-production-must-be-at-least-32-chars-long"
JWT_EXPIRES_IN="15m"
REFRESH_TOKEN_EXPIRES_IN="7d"
PORT=3001
CORS_ORIGIN="http://localhost:5173"
NODE_ENV="development"

# DeepL auto-translation (optional). Leave empty to disable the admin
# auto-translate button. Free-tier keys end with ":fx" and use the free
# endpoint automatically; paste a Pro key (without ":fx") later to upgrade —
# no code change needed. Get a free key at https://www.deepl.com/pro-api
DEEPL_API_KEY=""

# ─────────────────────────────────────────────────────────────────────────────
# PRODUCTION (set these in the host dashboard, e.g. Render — never commit .env)
# See docs/deployment/deploy.md. Summary:
#
#   NODE_ENV=production
#     → refresh cookie becomes Secure + SameSite=None (needed when the frontend
#       and backend are on different domains, e.g. Vercel + Render).
#
#   DATABASE_URL / DIRECT_URL → the production Supabase/Postgres project
#     (same format as above). The Prisma provider is already postgresql.
#
#   JWT_SECRET=<output of: openssl rand -base64 48>   # strong, unique
#   CORS_ORIGIN=https://your-domain.example            # exact frontend origin
#   DEEPL_API_KEY=<your key>                            # optional
#   PORT is provided by most hosts automatically.
# ─────────────────────────────────────────────────────────────────────────────
