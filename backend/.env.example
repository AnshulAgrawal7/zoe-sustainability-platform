DATABASE_URL="file:./dev.db"
JWT_SECRET="change-this-in-production-must-be-at-least-32-chars-long"
JWT_EXPIRES_IN="15m"
REFRESH_TOKEN_EXPIRES_IN="7d"
PORT=3001
CORS_ORIGIN="http://localhost:5173"
NODE_ENV="development"

# DeepL auto-translation (optional). Leave empty to disable the admin
# auto-translate button. Free-tier keys end with ":fx" and use the free
# endpoint automatically; paste a Pro key (without ":fx") later to upgrade —
# no code change needed. Get a free key at https://www.deepl.com/pro-api
DEEPL_API_KEY=""
