VITE_API_BASE_URL=http://localhost:3001/api
VITE_IS_PROTOTYPE=true

# --- Web analytics (OPTIONAL, privacy-friendly, cookieless) ---
# Leave EMPTY to disable all tracking (default — no cookie banner needed).
# See docs/deployment/analytics.md for setup.
# Provider: "plausible" or "umami" (anything else / empty = off)
VITE_ANALYTICS_PROVIDER=
# Plausible: your verified site domain (e.g. zoe-corfu-demo.org)
VITE_ANALYTICS_DOMAIN=
# Umami: the website id from your Umami dashboard
VITE_ANALYTICS_WEBSITE_ID=
# Script URL — optional for Plausible Cloud (defaults to https://plausible.io/js/script.js);
# REQUIRED for Umami or any self-hosted instance (e.g. https://analytics.example.org/script.js)
VITE_ANALYTICS_SRC=
